FROM python:3.12-slim

WORKDIR /app

# Tools for exploitation (curl, netcat, gcc for compiling, nmap for scanning)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl netcat-openbsd gcc make nmap socat \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir anthropic requests

COPY harnesses/ ./harnesses/

RUN mkdir -p /workspace /patches /app/logs \
    && chmod +x /app/harnesses/entrypoint.sh

WORKDIR /workspace

ENTRYPOINT ["bash", "/app/harnesses/entrypoint.sh"]
